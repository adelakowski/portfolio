{
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "cleanUrls": true,
        "rewrites": [
            {
                "source": "/projects/__next.projects.__PAGE__.txt",
                "destination": "/projects/__next.projects/__PAGE__.txt"
            },
            {
                "source": "/contact/__next.contact.__PAGE__.txt",
                "destination": "/contact/__next.contact/__PAGE__.txt"
            },
            {
                "source": "/_not-found/__next._not-found.__PAGE__.txt",
                "destination": "/_not-found/__next._not-found/__PAGE__.txt"
            },
            {
                "source": "/api/**",
                "run": {
                    "serviceId": "portfolio",
                    "region": "us-central1"
                }
            }
        ],
        "headers": [
            {
                "source": "**/*.@(html|json)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            },
            {
                "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|js|css|woff2)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "max-age=31536000, immutable"
                    }
                ]
            }
        ]
    }
}